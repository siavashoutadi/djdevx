from pydantic import EmailStr
from typing import Any

from settings.utils.base_settings import AppBaseSettings


class EmailSettings(AppBaseSettings):
    email_backend: str = "django.core.mail.backends.smtp.EmailBackend"
    django_default_from_email: EmailStr
    django_server_email: EmailStr

    @classmethod
    def get_dev_defaults(cls) -> dict[str, Any]:
        return {
            "email_backend": "django.core.mail.backends.console.EmailBackend",
            "django_default_from_email": "noreply@example.com",
            "django_server_email": "server@example.com",
        }


_email = EmailSettings()

EMAIL_BACKEND = _email.email_backend
DJANGO_DEFAULT_FROM_EMAIL = _email.django_default_from_email
DJANGO_SERVER_EMAIL = _email.django_server_email
